# Sao chép file này thành .env và điền giá trị thực:
#   cp .env.example .env

# --- MySQL ---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_strong_password
DB_NAME=password_security

# --- Mã hóa AES-256-GCM (64 ký tự hex = 32 bytes) ---
# Tạo key mới: python -c "import os; print(os.urandom(32).hex())"
MASTER_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# (Tùy chọn) Key cũ dạng base64 — chỉ dùng khi migrate từ phiên bản trước
# ENCRYPTION_KEY=